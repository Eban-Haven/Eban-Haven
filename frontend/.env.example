# Copy to .env.local for local development (never commit secrets).

# Supabase (Dashboard → Project Settings → API)
# Use "anon" / "public" key — not the service_role key.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Required on Vercel: public URL of your deployed ASP.NET API (no trailing slash).
# Example: https://your-api.railway.app
# Leave unset locally to use Vite devServer proxy → localhost API.
# VITE_API_BASE_URL=https://your-api.example.com

# --- On the API host (Azure/Railway/Render), set environment variables, e.g.:
# Supabase__Url=https://YOUR_PROJECT_REF.supabase.co
# Supabase__JwtSecret=<JWT Secret from Supabase Dashboard → Project Settings → API>
# Cors__Origins__0=https://your-app.vercel.app
# Cors__Origins__1=http://localhost:5173
