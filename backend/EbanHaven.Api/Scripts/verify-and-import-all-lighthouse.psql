-- Runs verify/import scripts for all Lighthouse CSV-backed tables.
--
-- Run from repo root:
--   cd "/Users/ethan/Desktop/Documents IS Junior Core (WINTER)/INTEX/Eban-Haven"
--   psql "host=<server>.postgres.database.azure.com port=5432 dbname=<db> user=<user> sslmode=require" -f "backend/EbanHaven.Api/Scripts/verify-and-import-all-lighthouse.psql"
--
-- This uses \i to include other scripts; paths are relative to where you run psql.

\set ON_ERROR_STOP on
\pset pager off

\echo '== Lighthouse import: safehouses =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-safehouses.psql

\echo '== Lighthouse import: residents =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-residents.psql

\echo '== Lighthouse import: supporters =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-supporters.psql

\echo '== Lighthouse import: donations =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-donations.psql

\echo '== Lighthouse import: donation allocations =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-donation-allocations.psql

\echo '== Lighthouse import: in-kind donation items =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-in-kind-donation-items.psql

\echo '== Lighthouse import: process recordings =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-process-recordings.psql

\echo '== Lighthouse import: home visitations =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-home-visitations.psql

\echo '== Lighthouse import: intervention plans =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-intervention-plans.psql

\echo '== Lighthouse import: education records =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-education-records.psql

\echo '== Lighthouse import: health wellbeing records =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-health-wellbeing-records.psql

\echo '== Lighthouse import: incident reports =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-incident-reports.psql

\echo '== Lighthouse import: public impact snapshots =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-public-impact-snapshots.psql

\echo '== Lighthouse import: safehouse monthly metrics =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-safehouse-monthly-metrics.psql

\echo '== Lighthouse import: partners =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-partners.psql

\echo '== Lighthouse import: partner assignments =='
\i backend/EbanHaven.Api/Scripts/verify-and-import-partner-assignments.psql

